lov boolean (
    name: BOOLEAN
    source {
        location: staticValues
    }

    entry false (
        sequence: 2
        display: No
        return: FALSE
    )

    entry true (
        sequence: 1
        display: Yes
        return: TRUE
    )

)

lov dept-dname (
    name: DEPT.DNAME
    source {
        tableName: DEPT
    }
    columnMapping {
        return: DEPTNO
        display: DNAME
        defaultSort: DNAME
    }
)

